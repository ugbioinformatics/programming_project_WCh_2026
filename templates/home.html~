{% extends "base.html" %}
{% block content %}

<p>
<form action="post/suma/" method="POST" >
                 {% csrf_token %}
                 {{ form }}
<button type="submit" class="save btn btn-default">Save & submit</button>
</form>

</div>
{% for post in post_list %}
